# ============================================================================
# Simulyn — production environment variables (copy to deploy/.env.prod and edit)
# ============================================================================
# Never commit the filled-in .env.prod. It is already in .gitignore.
# Generate secrets where indicated; NEVER reuse the example values below.

# ---------------------------------------------------------------------------
# DOMAIN & TLS
# ---------------------------------------------------------------------------
# Both must be A-records pointing at your VPS public IP.
SIMULYN_DOMAIN=app.example.com
SIMULYN_API_DOMAIN=api.example.com
# Used by Let's Encrypt for cert-expiry notices. Must be a real inbox.
ACME_EMAIL=ops@example.com

# Bakes into the Next.js browser bundle at build time. Always https://<api-domain>.
PUBLIC_API_URL=https://api.example.com

# ---------------------------------------------------------------------------
# POSTGRES
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_long_random_string

# ---------------------------------------------------------------------------
# JWT SIGNING KEY
# ---------------------------------------------------------------------------
# MUST be >= 32 characters. Generate with: openssl rand -base64 48
# Never reuse the dev key. Rotating invalidates all active sessions.
JWT_SIGNING_KEY=CHANGE_ME_generated_with_openssl_rand_base64_48

# ---------------------------------------------------------------------------
# PLATFORM ADMINS
# ---------------------------------------------------------------------------
# Comma-separated list of email addresses that get /admin/* access. Must match
# the email you use to register the first user. Add pilot contacts later.
PLATFORM_ADMIN_EMAILS=you@example.com

# ---------------------------------------------------------------------------
# AI PROVIDERS — cost-saving fallback chain
# ---------------------------------------------------------------------------
# Simulyn tries providers in LLM_PROVIDERS order. Each provider is skipped if
# its API key is empty, so it's safe (and recommended) to configure several:
# Groq fails → OpenRouter tries → Hugging Face tries → OpenAI tries → ...
# → friendly offline message. This is what makes the chat copilot stay up
# even when a single provider is rate-limited, down, or blocking your account.
#
# Default chain order (override with LLM_PROVIDERS to reorder or shrink):
#   groq → openrouter
# Append ",huggingface,openai,anthropic" if you configure those keys too.
# Add "gemini" to the front once your GCP project has billing enabled.
LLM_PROVIDERS=groq,openrouter

# --- Groq (primary — fastest, generous free tier) -------------------------
# Get a key at https://console.groq.com/keys (starts with `gsk_`)
# Free tier: ~14k req/day on llama-3.3-70b, 30 req/min hard limit.
GROQ_API_KEY=gsk_CHANGE_ME
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# --- OpenRouter (best fallback — multi-backend aggregator) ----------------
# Get a key at https://openrouter.ai/keys. Use ":free" suffix for $0 models.
# OpenRouter auto-fails-over between ~5 backend providers per model, so this
# single slot is effectively a fallback-inside-a-fallback. Free credit ($1)
# on signup, no card required for free models.
#
# Verified free chat models (re-check with GET https://openrouter.ai/api/v1/models):
#   deepseek/deepseek-v4-flash:free                          (DEFAULT — most reliable)
#   cognitivecomputations/dolphin-mistral-24b-venice-edition:free
#   meta-llama/llama-3.2-3b-instruct:free                    (smallest, fastest)
# AVOID: meta-llama/llama-3.3-70b-instruct:free → frequently 429s upstream.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash:free
# Attribution headers (recommended — usage shows on your OpenRouter dashboard)
OPENROUTER_HTTP_REFERER=https://app.example.com
OPENROUTER_X_TITLE=Simulyn AI

# --- Hugging Face Inference Providers (last free resort) -----------------
# Get a token at https://huggingface.co/settings/tokens (kind: "Read")
# Free tier is throttled and chat tool-calling quality varies by model.
# Pricing: https://huggingface.co/docs/inference-providers
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- Gemini (currently disabled — see note below) ------------------------
# Re-enable by adding "gemini," to the front of LLM_PROVIDERS once your GCP
# project has billing enabled. The free tier 403s on restricted GCP projects;
# create the key in a brand-new GCP project at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (paid; leave blank to skip) -----------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (paid; leave blank to skip) --------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Per-provider call timeout, in seconds. Each provider in the chain gets this
# many seconds to respond before we fall through to the next. Default is 30s;
# raise this if upstream providers are slow under load and you'd rather wait
# than fall through to the next provider.
LLM_TIMEOUT_SECS=30

# Per-org daily LLM budget caps. Units are MILLS (1/1000 USD), NOT dollars,
# so 5000 = $5, 20000 = $20. Keep conservative during pilot — bump after the
# first month when you've measured real per-org spend.
BUDGET_SOFT_CAP_MILLS=1000
BUDGET_HARD_CAP_MILLS=2000

# ---------------------------------------------------------------------------
# EMAIL — Resend (optional; leave empty to log emails to stdout)
# ---------------------------------------------------------------------------
# Sign up at https://resend.com, verify your sending domain, create an API key.
# EMAIL_PROVIDER=auto picks Resend when RESEND_API_KEY is present, else console.
EMAIL_PROVIDER=auto
RESEND_API_KEY=
RESEND_FROM_ADDRESS=Simulyn <noreply@example.com>

# ---------------------------------------------------------------------------
# STRIPE — self-serve billing (optional; leave empty to disable checkout UI)
# ---------------------------------------------------------------------------
# Get keys at https://dashboard.stripe.com/apikeys. Use LIVE keys in prod.
# Create one price per plan you sell. The frontend pricing card uses "Pro"
# (and "Enterprise" is sales-led). Add Team/Business if you launch more tiers.
# Webhook endpoint: https://api.example.com/api/billing/webhook
# Subscribe to events: checkout.session.completed,
#                      customer.subscription.updated,
#                      customer.subscription.deleted,
#                      customer.subscription.paused
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
# Optional extra tiers — leave blank if you don't sell them yet:
STRIPE_TEAM_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ---------------------------------------------------------------------------
# SENTRY — error monitoring (optional but strongly recommended for pilot)
# ---------------------------------------------------------------------------
# Create a .NET project at https://sentry.io and paste its DSN.
SENTRY_DSN_BACKEND=
