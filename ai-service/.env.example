# Simulyn AI service — LLM configuration
# Copy to .env (or .env.local) and fill in the block that matches your provider.
# Without any provider configured, the service falls back to deterministic text.

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# Options: openai | anthropic | ollama | auto | off   (default: auto)
#   - "openai" also works with Groq / DeepSeek / Together / OpenRouter / Azure —
#     they all speak the OpenAI protocol. Just set OPENAI_BASE_URL below.
LLM_PROVIDER=auto

# ---------------------------------------------------------------------------
# Recipe A — OpenAI (hosted, best quality, paid)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Recipe B — Groq (hosted, generous free tier, fast Llama / Qwen models)
# ---------------------------------------------------------------------------
# Signup: https://console.groq.com (free, no credit card)
# Free tier (per day): llama-3.1-8b-instant = 14,400 req / 500k tok
#                      llama-3.3-70b-versatile = 1,000 req / 100k tok
# LLM_PROVIDER=openai
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile      # narrative (higher quality, 1k RPD)
# OPENAI_CHAT_MODEL=llama-3.1-8b-instant    # chat (high volume, 14.4k RPD)

# ---------------------------------------------------------------------------
# Recipe C — DeepSeek (cheapest paid, OpenAI-compatible)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Recipe D — Together AI (open-weight models, cheap)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ---------------------------------------------------------------------------
# Recipe E — Anthropic (hosted, premium narrative quality)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ---------------------------------------------------------------------------
# Recipe F — Local Ollama (free, private, runs on your machine)
# ---------------------------------------------------------------------------
# Install: https://ollama.com   then: ollama pull llama3.2
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_TIMEOUT_SECS=60
# OLLAMA_CHAT_MODEL is optional; if unset it inherits OLLAMA_MODEL. Override
# with a larger tool-capable model (e.g. llama3.1:8b) for better chat quality.
# OLLAMA_CHAT_MODEL=llama3.1:8b

# ---------------------------------------------------------------------------
# Tuning (applies to whichever provider is active)
# ---------------------------------------------------------------------------
LLM_TIMEOUT_SECS=15
LLM_MAX_TOKENS=350
CHAT_MAX_TOKENS=1500
