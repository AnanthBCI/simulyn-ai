# Simulyn AI — environment template.
# Copy to .env, fill in the placeholders, then `docker compose up --build` (or run services natively).
# Every variable below has a working default, so an untouched .env starts a functional local stack —
# emails print to stdout, billing returns 503 on checkout, Sentry is silent.

# ---------------------------------------------------------------
# .NET API (backend/Simulyn.Api)
# ---------------------------------------------------------------
ConnectionStrings__Default=Host=localhost;Database=simulyn;Username=postgres;Password=postgres
Jwt__Key=CHANGE_ME_min_32_chars_dev_key_CHANGE_ME
Jwt__Issuer=Simulyn.Api
Jwt__Audience=Simulyn.Clients
AiService__BaseUrl=http://localhost:8000
Frontend__Origin=http://localhost:3000
PlatformAdminEmails=

# Email: leave Email__Resend__ApiKey empty to keep sending to stdout (logs only).
Email__Provider=auto
Email__FromAddress="Simulyn AI <noreply@simulyn.ai>"
Email__AppUrl=http://localhost:3000
Email__Resend__ApiKey=

# Sentry: leave empty for local dev; set in prod to forward errors.
Sentry__Dsn=

# LLM budget guardrail — 1000 mills = $1.
Budget__SoftCapMills=5000
Budget__HardCapMills=20000

# Stripe: empty = /api/billing/checkout returns 503 (still useful, the rest of the app works).
Stripe__ApiKey=
Stripe__WebhookSecret=
Stripe__Prices__Starter=
Stripe__Prices__Pro=
Stripe__Prices__Enterprise=
Stripe__SuccessUrl=http://localhost:3000/admin/billing?checkout=success
Stripe__CancelUrl=http://localhost:3000/admin/billing?checkout=cancel

# ---------------------------------------------------------------
# AI service (ai-service) — fallback chain
# ---------------------------------------------------------------
# Order of providers tried for every AI call. First success wins; if all fail
# the service returns deterministic / canned text so the app keeps working.
# Providers without an API key are silently skipped, so leaving any blank
# below just removes that step from the chain.
#
# Default auto-chain (used when LLM_PROVIDER=auto and LLM_PROVIDERS is empty):
#   gemini → groq → openrouter → huggingface → openai → anthropic [→ ollama]
LLM_PROVIDERS=groq,openrouter,huggingface,ollama
LLM_PROVIDER=auto
LLM_ENABLE_OLLAMA=1

# Gemini — disabled by default (current GCP keys 403 until billing enabled).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=

# Groq — fast/cheap, recommended primary.
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# OpenRouter — multi-backend aggregator, free models with ":free" suffix.
# https://openrouter.ai/keys
# Tip: try `google/gemini-2.0-flash-exp:free` for Gemini access without billing.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_CHAT_MODEL=
OPENROUTER_HTTP_REFERER=http://localhost:3001
OPENROUTER_X_TITLE=Simulyn AI (dev)

# Hugging Face Inference Providers — last free resort, throttled.
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct
HUGGINGFACE_CHAT_MODEL=

# OpenAI (and any OpenAI-compat via OPENAI_BASE_URL).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Ollama (local). Used if LLM_ENABLE_OLLAMA=1 OR you put "ollama" in LLM_PROVIDERS.
# Pull a tool-capable model first: `ollama pull llama3.1:8b`
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_CHAT_MODEL=llama3.1:8b

# ---------------------------------------------------------------
# Frontend (frontend)
# ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000
