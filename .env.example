# Simulyn AI — environment template.
# Copy to .env, fill in the placeholders, then `docker compose up --build` (or run services natively).
# Every variable below has a working default, so an untouched .env starts a functional local stack —
# emails print to stdout, billing returns 503 on checkout, Sentry is silent.

# ---------------------------------------------------------------
# .NET API (backend/Simulyn.Api)
# ---------------------------------------------------------------
ConnectionStrings__Default=Host=localhost;Database=simulyn;Username=postgres;Password=postgres
Jwt__Key=CHANGE_ME_min_32_chars_dev_key_CHANGE_ME
Jwt__Issuer=Simulyn.Api
Jwt__Audience=Simulyn.Clients
AiService__BaseUrl=http://localhost:8000
Frontend__Origin=http://localhost:3000
PlatformAdminEmails=

# Email: leave Email__Resend__ApiKey empty to keep sending to stdout (logs only).
Email__Provider=auto
Email__FromAddress="Simulyn AI <noreply@simulyn.ai>"
Email__AppUrl=http://localhost:3000
Email__Resend__ApiKey=

# Sentry: leave empty for local dev; set in prod to forward errors.
Sentry__Dsn=

# LLM budget guardrail — 1000 mills = $1.
Budget__SoftCapMills=5000
Budget__HardCapMills=20000

# Stripe: empty = /api/billing/checkout returns 503 (still useful, the rest of the app works).
Stripe__ApiKey=
Stripe__WebhookSecret=
Stripe__Prices__Starter=
Stripe__Prices__Pro=
Stripe__Prices__Enterprise=
Stripe__SuccessUrl=http://localhost:3000/admin/billing?checkout=success
Stripe__CancelUrl=http://localhost:3000/admin/billing?checkout=cancel

# ---------------------------------------------------------------
# AI service (ai-service)
# ---------------------------------------------------------------
LLM_PROVIDER=auto
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_CHAT_MODEL=llama3.1:8b

# ---------------------------------------------------------------
# Frontend (frontend)
# ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000
